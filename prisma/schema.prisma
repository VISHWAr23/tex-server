generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int             @id @default(autoincrement())
  email          String          @unique
  password       String
  name           String
  role           Role            @default(WORKER)
  createdAt      DateTime        @default(now())
  monthlySalary  Float?
  attendance     Attendance[]
  salaryPayments SalaryPayment[]
  works          Work[]
}

model Attendance {
  id        Int              @id @default(autoincrement())
  date      DateTime
  status    AttendanceStatus @default(PRESENT)
  workId    Int?             @unique
  userId    Int
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  work      Work?            @relation(fields: [workId], references: [id])

  @@unique([date, userId])
  @@index([userId])
  @@index([date])
}

model Company {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  exports   Export[]

  @@index([name])
}

model Export {
  id              Int             @id @default(autoincrement())
  date            DateTime
  quantity        Int
  pricePerUnit    Float
  totalAmount     Float
  paymentReceived Boolean         @default(false)
  descriptionId   Int
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  companyId       Int
  company         Company         @relation(fields: [companyId], references: [id])
  description     WorkDescription @relation(fields: [descriptionId], references: [id])

  @@index([companyId])
  @@index([date])
  @@index([date, companyId])
}

model WorkDescription {
  id           Int      @id @default(autoincrement())
  text         String   @unique
  pricePerUnit Float?
  exports      Export[]
  works        Work[]

  @@index([text])
}

model Work {
  id            Int             @id @default(autoincrement())
  date          DateTime
  quantity      Int
  userId        Int
  createdAt     DateTime        @default(now())
  descriptionId Int
  pricePerUnit  Float
  totalAmount   Float
  updatedAt     DateTime        @updatedAt
  attendance    Attendance?
  description   WorkDescription @relation(fields: [descriptionId], references: [id])
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@index([date, userId])
}

model Material {
  id           Int      @id @default(autoincrement())
  name         String
  supplier     String
  quantity     Int
  cost         Float
  dateReceived DateTime @default(now())
}

model Product {
  id        Int       @id @default(autoincrement())
  name      String
  quantity  Int
  startDate DateTime
  endDate   DateTime?
  client    String
  revenue   Float?
}

model Expense {
  id       Int         @id @default(autoincrement())
  type     ExpenseType
  category String
  amount   Float
  date     DateTime    @default(now())
  note     String?
}

model SalaryPayment {
  id        Int      @id @default(autoincrement())
  amount    Float
  date      DateTime @default(now())
  note      String?
  userId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

enum Role {
  OWNER
  WORKER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
}

enum ExpenseType {
  COMPANY
  HOME
  HOME_INCOME
}
